// ============================================================
// CarbonLens — Prisma Schema
// ============================================================
// SQLite for MVP simplicity.
// All orgId-scoped queries enforce data isolation at app level.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Organization ──────────────────────────────────────────────
model Organization {
  id            String   @id @default(cuid())
  name          String
  industry      String
  reportingYear Int      @default(2026)
  createdAt     DateTime @default(now())

  users               User[]
  facilities          Facility[]
  emissionRecords     EmissionRecord[]
  suppliers           Supplier[]
  issues              Issue[]
  reports             Report[]
  supplierSubmissions SupplierSubmission[]
}

// ── User ──────────────────────────────────────────────────────
model User {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String   @unique
  passwordHash   String
  role           String   // UserRole: SUSTAINABILITY_MANAGER | OPERATIONS_ADMIN | SUPPLIER | LEADERSHIP_REVIEWER | ADMIN
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  assignedIssues Issue[]    @relation("IssueOwner")
  generatedReports Report[] @relation("ReportGenerator")
}

// ── Facility ─────────────────────────────────────────────────
model Facility {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  location       String
  type           String   // e.g. Manufacturing, Warehouse, Office
  createdAt      DateTime @default(now())

  organization    Organization     @relation(fields: [organizationId], references: [id])
  emissionRecords EmissionRecord[]
}

// ── EmissionFactor ────────────────────────────────────────────
model EmissionFactor {
  id              String   @id @default(cuid())
  name            String
  scope           String   // SCOPE_1 | SCOPE_2 | SCOPE_3
  category        String
  factorValue     Float    // kg CO2e per unit
  factorUnit      String   // e.g. "per liter", "per kWh"
  sourceReference String
  createdAt       DateTime @default(now())

  emissionRecords EmissionRecord[]
}

// ── EmissionRecord ────────────────────────────────────────────
model EmissionRecord {
  id                 String   @id @default(cuid())
  organizationId     String
  facilityId         String
  sourceType         String
  scope              String   // SCOPE_1 | SCOPE_2 | SCOPE_3
  category           String
  activityValue      Float
  activityUnit       String
  emissionFactorId   String?
  calculatedEmissions Float   @default(0)
  periodMonth        Int
  periodYear         Int
  status             String   @default("DRAFT") // DRAFT | SUBMITTED | ACCEPTED | REJECTED
  createdAt          DateTime @default(now())

  organization   Organization    @relation(fields: [organizationId], references: [id])
  facility       Facility        @relation(fields: [facilityId], references: [id])
  emissionFactor EmissionFactor? @relation(fields: [emissionFactorId], references: [id])
  issues         Issue[]         @relation("RecordIssues")
}

// ── Supplier ─────────────────────────────────────────────────
model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  contactName    String
  contactEmail   String
  category       String
  priorityTier   Int      @default(1) // 1=High, 2=Medium, 3=Low
  createdAt      DateTime @default(now())

  organization  Organization         @relation(fields: [organizationId], references: [id])
  submissions   SupplierSubmission[]
}

// ── SupplierSubmission ────────────────────────────────────────
model SupplierSubmission {
  id               String   @id @default(cuid())
  supplierId       String
  organizationId   String
  scope3Category   String
  activityValue    Float
  activityUnit     String
  reportingPeriod  String   // e.g. "2026-03"
  dataQualityScore Int      @default(0)
  status           String   @default("SUBMITTED") // SUBMITTED | ACCEPTED | REJECTED
  notes            String   @default("")
  createdAt        DateTime @default(now())

  supplier     Supplier     @relation(fields: [supplierId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
}

// ── Issue ─────────────────────────────────────────────────────
model Issue {
  id             String    @id @default(cuid())
  organizationId String
  recordType     String    // EMISSION_RECORD | SUPPLIER_SUBMISSION
  recordId       String
  title          String
  description    String
  severity       String    @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  status         String    @default("OPEN")   // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  ownerUserId    String?
  dueDate        DateTime?
  createdAt      DateTime  @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id])
  owner        User?           @relation("IssueOwner", fields: [ownerUserId], references: [id])
  record       EmissionRecord? @relation("RecordIssues", fields: [recordId], references: [id])
}

// ── Report ────────────────────────────────────────────────────
model Report {
  id                String   @id @default(cuid())
  organizationId    String
  title             String
  reportingPeriod   String   // e.g. "2026-Q1"
  summary           String   @default("")
  status            String   @default("GENERATED")
  generatedByUserId String
  createdAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  generatedBy  User         @relation("ReportGenerator", fields: [generatedByUserId], references: [id])
}
